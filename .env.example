# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/database_name
PGHOST=localhost
PGPORT=5432
PGUSER=username
PGPASSWORD=password
PGDATABASE=database_name

# Session Security
SESSION_SECRET=your-super-secure-session-secret-here

# API Key Encryption (Required for secure credential storage)
API_ENCRYPTION_KEY=your-32-character-encryption-key-here

# Stripe Payment Processing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# Print-on-Demand Services
PRINTFUL_API_KEY=your_printful_api_key_here
GOOTEN_PARTNER_BILLING_KEY=your_gooten_billing_key_here

# Shipping Services
USPS_CONSUMER_KEY=your_usps_consumer_key_here
USPS_CONSUMER_SECRET=your_usps_consumer_secret_here

# Google Analytics (Optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Development Environment
NODE_ENV=development

# Security Notes:
# - Never commit actual secrets to version control
# - Use strong, unique values for all secrets
# - Rotate secrets regularly in production
# - Store production secrets securely using your hosting platform's secret management