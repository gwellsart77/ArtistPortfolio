        available: true,
        stock: 100,
        artworkId: null,
      },
      {
        title: "Silk Scarf",
        description: "Abstract Bloom Design",
        price: 85,
        imageUrl: "https://images.unsplash.com/photo-1584917865442-de89df76afd3?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&h=400",
        type: "merchandise",
        available: true,
        stock: 25,
        artworkId: null,
      },
      {
        title: "Garden Dreams",
        description: "Original Oil on Canvas",
        price: 1250,
        imageUrl: "https://images.unsplash.com/photo-1579541814924-49fef17c5be5?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&h=400",
        type: "originals",
        available: true,
        stock: 1,
        artworkId: 8,
      }
    ];

    // Add products to storage
    productsData.forEach(product => {
      this.createProduct(product);
    });
  }
}

export const storage = new MemStorage();
